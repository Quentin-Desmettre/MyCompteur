# Clé secrète partagée entre l'app Android (réglage "Clé d'ingestion") et le serveur.
# Générez-en une longue et aléatoire, ex : openssl rand -hex 32
INGEST_KEY=changez-moi

# Mot de passe PostgreSQL
POSTGRES_PASSWORD=changez-moi-aussi
POSTGRES_USER=compteur
POSTGRES_DB=compteur

# Domaine public servi par Caddy (TLS automatique Let's Encrypt).
# Pour un test local sans domaine, utilisez l'API directement sur http://localhost:8000
DOMAIN=suivi.exemple.com
